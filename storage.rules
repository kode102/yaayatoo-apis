rules_version = '2';

// Lecture publique : URLs de téléchargement utilisables par le site vitrine sans auth.
// Écriture : comptes Firebase Auth uniquement (admin / upload). allow write: if request.auth != null;
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
