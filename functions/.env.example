# Variables lues par la Cloud Function `yaayatoo` (Help Desk SMTP, etc.).
# Copier vers `.env` pour l’émulateur local. En production, définir les mêmes
# clés dans la console Firebase (Functions → Configuration) ou via Secret Manager.

SMTP_HOST=smtp.example.com
SMTP_PORT=587
# true = TLS direct (souvent port 465). Pour STARTTLS sur 587, mettre false.
SMTP_SECURE=false
SMTP_USER=
# Mot de passe : l’un des deux suffit (SMTP_PASS est le nom documenté).
SMTP_PASS=
# SMTP_PASSWORD=

SMTP_FROM=
# Optionnel : nom affiché « From » (ex. YaaYaToo Services).
SMTP_FROM_NAME=
