rules_version = '2';

// Accès client (Web / mobile). L’Admin SDK (Cloud Functions) ignore ces règles.
// Par défaut : refus côté client. Ajustez si vous utilisez le SDK Firebase dans une app.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
